<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InfinitySolutions</title>
    <style>
        body { margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background-color: #f8f9fa; font-family: sans-serif; text-align: center; }
        .ribbon-container { cursor: pointer; transition: transform 0.3s ease; margin-bottom: 20px; }
        .ribbon-container:hover { transform: scale(1.1); }
        .ribbon-emoji { font-size: 80px; }
        #content { display: none; animation: fadeIn 1.5s ease-in-out; }
        .logo { width: 150px; margin-bottom: 15px; }
        .company-name { font-size: 28px; font-weight: bold; color: #003366; margin: 0; }
        .tagline { font-size: 18px; color: #555; font-style: italic; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="ribbon-container" id="ribbonBox" onclick="revealCompany()">
        <div class="ribbon-emoji">🎀</div>
        <p>Click the ribbon to open</p>
    </div>
    <div id="content">
        <img src="https://i.ibb.co/Vp8YjFm/infinity-logo.png" alt="Logo" class="logo">
        <h1 class="company-name">InfinitySolutions</h1>
        <p class="tagline">(limitless growth)</p>
    </div>
    <script>
        function revealCompany() {
            document.getElementById('ribbonBox').style.display = 'none';
            document.getElementById('content').style.display = 'block';
        }
    </script>
</body>
</html>
